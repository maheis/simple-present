{
  "bind": "0.0.0.0:8080",
  "database_path": "/var/lib/simplepresent/simplepresent.db",
  "tls": {
    "enabled": false,
    "cert_file": "",
    "key_file": ""
  },
  "security": {
    "require_tls": true,
    "trust_proxy_headers": true,
    "jwt_secret": "change-me-in-production",
    "account_policy": {
      "max_accounts": 200,
      "admin_email": "admin@example.com",
      "archive_after_days": 30,
      "warning_days": [
        14,
        7
      ],
      "sweep_interval_minutes": 60,
      "smtp": {
        "host": "smtp.example.com",
        "port": 587,
        "username": "simplepresent@example.com",
        "password": "change-me",
        "from": "simplepresent@example.com"
      }
    },
    "rate_limit": {
      "requests_per_minute": 60,
      "burst": 20
    },
    "quotas": {
      "max_devices": 5,
      "max_items": 10000,
      "max_bytes_per_account": 10485760
    }
  }
}
