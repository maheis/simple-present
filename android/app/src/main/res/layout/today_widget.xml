<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="8dp" android:background="#9910201D">

    <LinearLayout android:id="@+id/widget_header" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="6dp">

        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@mipmap/ic_launcher" android:contentDescription="icon" android:layout_marginEnd="8dp" />

        <ImageView android:id="@+id/widget_header_text" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:contentDescription="today" />

        <!-- Refresh button: taps trigger a broadcast handled by TodayWidgetProvider -->
        <ImageView android:id="@+id/widget_refresh" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_refresh" android:contentDescription="refresh" android:layout_marginStart="8dp" android:padding="4dp" />

    </LinearLayout>

    <ListView android:id="@+id/widget_list" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:divider="#2B4A45" android:dividerHeight="1dp" android:cacheColorHint="@android:color/transparent" android:transcriptMode="disabled" />

    <ImageView android:id="@+id/widget_empty" android:layout_width="match_parent" android:layout_height="wrap_content" android:contentDescription="no tasks" android:paddingTop="8dp" android:visibility="gone" android:scaleType="fitCenter" />
</LinearLayout>
